# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# Set to "false" to use the live Meta Marketing API.
# While true, the dashboard runs on bundled mock data (no API calls made).
USE_MOCK_DATA=true

# Meta Marketing API credentials.
# Required only when USE_MOCK_DATA=false.
META_AD_ACCOUNT_ID=act_000000000000000
META_APP_ID=000000000000000
META_APP_SECRET=00000000000000000000000000000000
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
